								 750 4530 1>;
				strategy_temp_range_t5 =	<1700 4570 0
								 1650 4565 0
								 1550 4550 0
								 1450 4540 0
								 1300 4530 1>;
			};
		};

		svooc_charge_strategy {
			strategy_soc_0_to_50 { /* 0 ~ 20 */
