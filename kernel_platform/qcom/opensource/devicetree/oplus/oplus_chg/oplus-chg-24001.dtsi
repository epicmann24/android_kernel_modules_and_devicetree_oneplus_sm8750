								 1050 4550 0
								 950 4540 0
								 800 4530 1>;
				strategy_temp_range_t5 =	<1950 4570 0
								 1900 4565 0
								 1800 4550 0
								 1700 4540 0
								 1550 4530 1>;
			};
		};
		svooc_lcf_strategy_1 {
			oplus,gauge_topic_name = "gauge:1";
			oplus,temp_type = <OPLUS_STRATEGY_USE_SHELL_TEMP>;
			oplus,temp_range = <0 50 120 160 200 350 430>;

