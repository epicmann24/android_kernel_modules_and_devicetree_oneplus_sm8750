&soc {
	dsi_panel_boe_nt37706a_fhd_plus_144hz_vid {
		qcom,dsi-display-active;
	};
};

&dsi_panel_boe_nt37706a_fhd_plus_144hz_vid {
	qcom,panel-supply-entries = <&oplus_dsi_panel_custom_pwr_supply>;
	qcom,mdss-dsi-panel-controller = <&mdss_dsi0>;
	qcom,mdss-dsi-bl-pmic-control-type = "bl_ctrl_dcs";
	qcom,bl-update-flag = "delay_until_first_frame";
	qcom,mdss-dsi-bl-min-level = <1>;
	qcom,mdss-dsi-bl-max-level = <4095>;
	qcom,mdss-brightness-max-level = <4095>;
	oplus,dsi-bl-normal-max-level = <3626>;
	oplus,dsi-brightness-normal-max-level = <3626>;
	oplus,dsi-dc-backlight-threshold = <1960>;
	oplus,dsi-brightness-default-level = <1638>;
	qcom,platform-te-gpio = <&tlmm 17 0>;
	qcom,platform-reset-gpio = <&tlmm 12 0>;

	oplus,panel-reset-position = <0x02>;
	oplus,panel-power-on-sequence = "10", "vddio", "10", "vdd", "10", "vci", "10";
	oplus,panel-power-off-sequence = "10", "vci", "10", "vdd", "10", "vddio", "10";

	qcom,mdss-dsi-bl-inverted-dbv;
	qcom,ulps-enabled;
	qcom,dsi-select-clocks = "pll_byte_clk0", "pll_dsi_clk0";
	/* ofp config */
	//oplus,ofp-fp-type = <0x90>;
	//oplus,ofp-need-to-wait-data-before-aod-on;

	/* adfr config */
	/* just for qsync enable*/
	//qcom,qsync-enable;
	//qcom,mdss-dsi-qsync-min-refresh-rate = <24>;
	/*
	** 0st bit: adfr global on/off
	** 1st bit: fakeframe on/off
	** 2st bit: switch on/off
	** 3rd bit: 0:double-TE switch 1:external TE/TP switch
	** 4rd bit: idle mode on/off
	** 5th bit: temperature compensation mode on/off
	*/
	/*
	 oplus,adfr-config = <0x1051>;  // 0b1110'0101'0001
	 oplus,adfr-test-te-gpio = <&tlmm 85 0>;
	 */

	/* fps-switch */
	/*qcom,mdss-dsi-pan-enable-dynamic-fps;
	qcom,mdss-dsi-pan-fps-update = "dfps_immediate_porch_mode_custom";
	qcom,dsi-supported-dfps-list = <144 120 90 60>;
	qcom,dsi-dfps-hbp-list = <20 20 20 20>;
	qcom,dsi-dfps-hfp-list = <57 157 157 157>;
	qcom,dsi-dfps-hpw-list = <4 4 4 4>;
	qcom,dsi-dfps-vbp-list = <26 26 26 26>;
	qcom,dsi-dfps-vfp-list = <116 124 1108 3076>;
	qcom,dsi-dfps-vpw-list = <2 2 2 2>;
	qcom,mdss-dsi-min-refresh-rate = <60>;
	qcom,mdss-dsi-max-refresh-rate = <144>;*/

	/* vid-timming-switch */
	//oplus,dsi-vid-timming-switch_enable;
	//oplus,dsi-vidmode-backlight-async-wait-enable;
	//oplus,dsi-set-backlight-not-do-esd-reg-read-enable;

	qcom,mdss-dsi-display-timings {
		timing@sa_fhd_120 { /* FHD+ 120hz 1292Mbps */
			qcom,mdss-dsi-panel-phy-timings = [00 2A 0B 0B 1C 1A 0B 0C 0B 02 04 00 23 10];
			qcom,display-topology = <1 1 1>,<2 2 1>;
			qcom,default-topology-index = <1>;
			//qcom,dsi-dyn-clk-list = <1112000000 1056000000>;
		};
	};
};
&dsi_panel_boe_nt37706a_fhd_plus_144hz_vid {
	qcom,panel_voltage_vddi_name = "vddio";
	qcom,panel_voltage_vddi = <0 1800000 1850000 1950000>;
 	qcom,panel_voltage_vddr_name = "vdd";
	qcom,panel_voltage_vddr = <1 1200000 1200000 1200000>;
 	qcom,panel_voltage_vci_name = "vci";
 	qcom,panel_voltage_vci = <1 3000000 3200000 3300000>;
};

